# Tayari Backend Configuration

# Groq API key for advisory generation (fast LLM inference)
# Get your free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Twilio SMS — set all three to send real SMS; leave blank to simulate.
# Find the SID + Auth Token on your Twilio Console dashboard; FROM is your
# Twilio phone number in E.164 format. On a trial account you can only send to
# numbers you have verified in the console.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+14787806879

# Database
DATABASE_URL=sqlite+aiosqlite:///./tayari.db

# Environment
ENVIRONMENT=development
LOG_LEVEL=info

# Hugging Face token — powers NLLB-200 advisory translation (Amharic, Oromo,
# Dinka, Somali, Swahili, Arabic) and MMS-TTS voice notes. Get a free token at
# https://huggingface.co/settings/tokens. Either HF_TOKEN or HF_API_TOKEN works.
# Without it, translation falls back to the Groq LLM.
HF_TOKEN=hf_your_token_here
