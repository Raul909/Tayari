# Tayari Backend Configuration

# Anthropic (Claude) API key for advisory generation
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Africa's Talking SMS (sandbox mode)
AT_USERNAME=sandbox
AT_API_KEY=your_sandbox_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./tayari.db

# Environment
ENVIRONMENT=development
LOG_LEVEL=info
