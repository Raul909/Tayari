# Tayari Backend Configuration

# Groq API key for advisory generation (fast LLM inference)
# Get your free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Africa's Talking SMS (sandbox mode)
AT_USERNAME=sandbox
AT_API_KEY=your_sandbox_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./tayari.db

# Environment
ENVIRONMENT=development
LOG_LEVEL=info
HF_TOKEN=hf_your_token_here
