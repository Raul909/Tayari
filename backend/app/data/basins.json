      "country": "Somalia",
      "gauge_point": {
        "latitude": 3.80,
        "longitude": 42.54
      },
      "upstream_point": {
        "latitude": 5.5,
        "longitude": 41.0
      },
      "flood_threshold_m3s": 500,
      "warning_threshold_m3s": 380,
      "historical_median_m3s": 150,
      "description": "The Juba River at Luuq is Southern Somalia's primary flood risk. The river originates in the Ethiopian highlands and regularly floods during the Deyr (Oct-Dec) and Gu (Apr-Jun) rain seasons."
    },
    {
      "id": "tana",
      "name": "Tana Basin (Garsen)",
      "river": "Tana River",
      "country": "Kenya",
      "gauge_point": {
        "latitude": -2.27,
        "longitude": 40.12
      },
      "upstream_point": {
        "latitude": -0.5,
        "longitude": 37.5
      },
      "flood_threshold_m3s": 800,
      "warning_threshold_m3s": 600,
      "historical_median_m3s": 200,
      "description": "Kenya's longest river, the Tana, floods at Garsen near its delta. The lower Tana basin is home to vulnerable pastoral and farming communities. Major floods occurred in April-May 2024."
    },
    {
      "id": "nzoia",
      "name": "Nzoia Basin (Budalangi)",
      "river": "Nzoia River",
      "country": "Kenya",
      "gauge_point": {
        "latitude": 0.10,
        "longitude": 34.05
      },
      "upstream_point": {
        "latitude": 0.61,
        "longitude": 34.77
      },
      "flood_threshold_m3s": 300,
      "warning_threshold_m3s": 220,
      "historical_median_m3s": 90,
      "description": "The Nzoia River bursts its banks at Budalangi (Bunyala) in the Lake Victoria basin almost every rainy season, making it one of Kenya's most chronically flooded areas. It drains the Cherangani Hills and Mt Elgon and floods heavily during the long (MAM) and short (OND) rains."
    },
    {
      "id": "awash",
      "name": "Awash Basin (Dubti)",
      "river": "Awash River",
      "country": "Ethiopia",
      "gauge_point": {
        "latitude": 11.73,
        "longitude": 41.08
      },
      "upstream_point": {
        "latitude": 8.90,
        "longitude": 39.10
      },
      "flood_threshold_m3s": 500,
      "warning_threshold_m3s": 380,
      "historical_median_m3s": 120,
      "description": "The lower Awash floods across the Afar lowlands around Dubti and Asaita, fed by rains over the central Ethiopian highlands near Koka. Overflow displaced tens of thousands of Afar pastoralists in 2020, 2023 and 2024."
    },
    {
      "id": "white_nile",
      "name": "White Nile Basin (Bor)",
      "river": "White Nile",
      "country": "South Sudan",
      "gauge_point": {
        "latitude": 6.21,
        "longitude": 31.56
      },
      "upstream_point": {
        "latitude": 5.20,
        "longitude": 31.77
      },
      "flood_threshold_m3s": 1300,
      "warning_threshold_m3s": 1050,
      "historical_median_m3s": 800,
      "description": "Around Bor and the Sudd in Jonglei, sustained high White Nile flows driven by Lake Victoria outflow produced catastrophic multi-year flooding from 2020-2022, affecting over a million people across South Sudan."
    },
    {
      "id": "blue_nile",
      "name": "Blue Nile Basin (Khartoum)",
      "river": "Blue Nile",
      "country": "Sudan",
      "gauge_point": {
        "latitude": 15.55,
        "longitude": 32.53
      },
      "upstream_point": {
        "latitude": 12.00,
        "longitude": 37.25
      },
      "flood_threshold_m3s": 5500,
      "warning_threshold_m3s": 4000,
      "historical_median_m3s": 1400,
      "description": "The Blue Nile carries Ethiopian highland (Lake Tana) rains into Sudan, cresting at Khartoum in the July-September flood season. Record 2020 levels inundated riverside districts and affected roughly 875,000 people nationwide."
    },
    {
      "id": "omo",
      "name": "Omo Basin (Omorate)",
      "river": "Omo River",
      "country": "Ethiopia",
      "gauge_point": {
        "latitude": 4.80,
        "longitude": 35.96
      },
      "upstream_point": {
        "latitude": 7.00,
        "longitude": 37.30
      },
      "flood_threshold_m3s": 900,
      "warning_threshold_m3s": 700,
      "historical_median_m3s": 250,
      "description": "The lower Omo floods the South Omo Zone around Omorate before draining into Lake Turkana. Seasonal overbank flooding repeatedly displaces Dassanech and Nyangatom agro-pastoralist communities, notably in 2019 and 2023."
    }
